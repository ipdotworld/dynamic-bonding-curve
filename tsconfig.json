{
  "compilerOptions": {
    "types": ["mocha", "chai"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2020"],
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "strict": false
  },
  "include": ["tests/**/*.ts"],
  "exclude": [
    "node_modules",
    "tests/_quarantine_removed_features",
    "tests/fork"
  ]
}
